{
    "distSpecVersion": "1.1.1",
    "storage": {
        "rootDirectory": "/tmp/zot/local",
        "gc": true,
        "gcDelay": "20s",
        "gcInterval": "1s"
    },
    "http": {
        "address": "127.0.0.1",
        "port": "8080",
        "readTimeout": "15m",
        "writeTimeout": "15m"
    },
    "log": {
        "level": "debug",
        "output": "/tmp/gc-bench-local.log"
    }
}
