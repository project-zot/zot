{
  "storage": {
    "rootDirectory": "/tmp/zot",
    "dedupe": false,
    "storageDriver": {
      "name": "azure",
      "rootdirectory": "/zot",
      "accountname": "myazurestorageaccount",
      "container": "zot-storage",
      "credentials": {
        "type": "default_credentials"
      }
    }
  },
  "http": {
    "address": "127.0.0.1",
    "port": "8080"
  },
  "log": {
    "level": "debug"
  }
}
